# docker-compose.yml shu fayldagi qiymatlarni o'qiydi. Nusxa oling:
#   cp .env.example .env
# va quyidagilarni haqiqiy (kuchli, tasodifiy) qiymatlar bilan to'ldiring.

DB_PASSWORD=
REDIS_PASSWORD=
# Kamida 32 belgili tasodifiy satr (JWT imzolash uchun)
JWT_SECRET=
# Aniq 32 belgili satr (AES-256) - pasport/karta ma'lumotlarini shifrlash uchun.
# E'TIBOR: bazada allaqachon shifrlangan ma'lumot bo'lsa, bu kalitni o'zgartirmang.
ENCRYPTION_KEY=
APP_CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
